{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/lib/dcc/*": ["../../lib/dcc/*"],
      "@/lib/route-governance": ["../../lib/route-governance"],
      "@/src/data/*": ["../../src/data/*"],
      "@/app/components/decision/*": ["../../app/components/decision/*"],
      "@/data/*": ["../../data/*"],
      "@/lib/getyourguide/*": ["../../lib/getyourguide/*"],
      "@/lib/wta/*": ["../../lib/wta/*"],
      "@/lib/db/*": ["../../lib/db/*"],
      "@/lib/session/*": ["../../lib/session/*"],
      "@/types/*": ["../../types/*"],
      "@/utils/*": ["../../utils/*"],
      "@/app/components/dcc/*": ["../../app/components/dcc/*"],
      "@/app/internal/*": ["../../app/internal/*"],
      "@/lib/handoff/*": ["../../lib/handoff/*"],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
