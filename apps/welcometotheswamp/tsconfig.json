{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/app/components/PartnerAnalyticsScript": ["../../lib/getyourguide/PartnerAnalyticsScript"],
      "@/app/components/ActivitiesWidget": ["../../app/components/ActivitiesWidget"],
      "@/app/components/AvailabilityWidget": ["../../app/components/AvailabilityWidget"],
      "@/app/components/network/types": ["../../app/components/network/types"],
      "@/lib/dcc/networkEntityJsonLd": ["../../lib/dcc/networkEntityJsonLd"],
      "@/lib/liveProductLinks": ["../../lib/liveProductLinks"],
      "@/lib/getyourguide/*": ["../../lib/getyourguide/*"],
      "@/lib/dcc/*": ["../../lib/dcc/*"],
      "@/lib/wta/*": ["../../lib/wta/*"],
      "@/lib/db/*": ["../../lib/db/*"],
      "@/lib/route-governance": ["../../lib/route-governance"],
      "@/data/*": ["../../data/*"],
      "@/src/*": ["../../src/*"],
      "@/*": ["./*"]
    },
    "noImplicitAny": false
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
